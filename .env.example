# --- GCP Vertex AI Configuration ---
# Your GCP Project ID (e.g., 'my-project-123')
GOOGLE_CLOUD_PROJECT=your_project_id_here

# GCP Region (e.g., 'us-central1' or 'asia-southeast1')
GOOGLE_CLOUD_REGION=us-central1

# Path to your Service Account JSON key (e.g., 'credentials/key.json')
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json

# Alternative for deploy (Railway): put the whole JSON content into this env var.
# If set, app will write it to a temp file and set GOOGLE_APPLICATION_CREDENTIALS automatically.
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account", ...}
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Optional: override model defaults
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.2
EMBEDDING_MODEL=text-embedding-005

# --- MongoDB Configuration ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=bpt_chatbot
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000

# --- Qdrant Configuration ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key_if_using_cloud
QDRANT_COLLECTION=bpt_docs
QDRANT_TIMEOUT_SECONDS=5

# Optional: chunking / retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
RETRIEVER_K=3

# --- Redis (RAG Response Cache) ---
# Example with Docker: redis://localhost:6379/0
# Leave empty to disable caching
REDIS_URL=redis://localhost:6379/0
REDIS_CONNECT_TIMEOUT_SECONDS=3
REDIS_SOCKET_TIMEOUT_SECONDS=3
# Cache TTL in seconds (e.g., 3600 = 1 hour)
RAG_CACHE_TTL_SECONDS=3600
# 1=enabled, 0=disabled
RAG_CACHE_ENABLED=1
# Namespace/prefix for keys
RAG_CACHE_PREFIX=rag:cache:v1
# Global data version key (bumped on every successful upload)
RAG_DATA_VERSION_KEY=rag:data_version

# --- Semantic Cache (Qdrant index + Redis value) ---
# 1=enabled, 0=disabled
SEMANTIC_CACHE_ENABLED=1
# Qdrant collection to store query embeddings for cache lookup
SEMANTIC_CACHE_COLLECTION=rag_query_cache
# Number of nearest cached queries to check
SEMANTIC_CACHE_LIMIT=5
# Minimum cosine similarity score to consider as cache hit (0-1)
SEMANTIC_CACHE_MIN_SCORE=0.92
# Minimal token coverage between new query and cached query (0-1)
SEMANTIC_CACHE_MIN_TOKEN_COVERAGE=0.65

# --- Support / Escalation ---
# Shown when info is not found in documents
SUPPORT_WHATSAPP=+62xxxxxxxxxxx
SUPPORT_TICKETING_URL=https://example.com/ticketing
SUPPORT_EMAIL=bpt@komdigi.go.id

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8000

# --- OCR Service (EasyOCR) ---
# Jika diisi, loader gambar akan memanggil service ini (bukan menjalankan EasyOCR di backend utama)
# Contoh: http://localhost:8001
OCR_SERVICE_URL=
# Bahasa OCR default (dipakai oleh service OCR dan juga request dari backend utama)
OCR_LANGS=id,en
