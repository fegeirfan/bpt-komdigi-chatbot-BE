# --- GCP Vertex AI Configuration ---
# Your GCP Project ID (e.g., 'my-project-123')
GOOGLE_CLOUD_PROJECT=your_project_id_here

# GCP Region (e.g., 'us-central1' or 'asia-southeast1')
GOOGLE_CLOUD_REGION=us-central1

# Path to your Service Account JSON key (e.g., 'credentials/key.json')
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json

# Optional: override model defaults
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.2
EMBEDDING_MODEL=text-embedding-005

# --- MongoDB Configuration ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=bpt_chatbot

# --- Qdrant Configuration ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key_if_using_cloud
QDRANT_COLLECTION=bpt_docs

# Optional: chunking / retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
RETRIEVER_K=3

# --- Redis (RAG Response Cache) ---
# Example with Docker: redis://localhost:6379/0
# Leave empty to disable caching
REDIS_URL=redis://localhost:6379/0
# Cache TTL in seconds (e.g., 3600 = 1 hour)
RAG_CACHE_TTL_SECONDS=3600
# 1=enabled, 0=disabled
RAG_CACHE_ENABLED=1
# Namespace/prefix for keys
RAG_CACHE_PREFIX=rag:cache:v1
# Global data version key (bumped on every successful upload)
RAG_DATA_VERSION_KEY=rag:data_version

# --- Support / Escalation ---
# Shown when info is not found in documents
SUPPORT_WHATSAPP=+62xxxxxxxxxxx
SUPPORT_TICKETING_URL=https://example.com/ticketing
SUPPORT_EMAIL=bpt@komdigi.go.id

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8000
